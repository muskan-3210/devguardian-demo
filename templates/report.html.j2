<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Extraction Report — {{ title }}</title>
  <style>
    body { font-family: system-ui, Arial, sans-serif; max-width: 760px;
           margin: 40px auto; padding: 0 16px; color: #222; line-height: 1.5; }
    h1 { font-size: 1.4rem; }
    .meta { background: #f4f6f8; border-radius: 8px; padding: 12px 16px;
            font-size: .9rem; margin-bottom: 24px; }
    .meta span { display: inline-block; margin-right: 18px; }
    .badge { background: #2563eb; color: #fff; border-radius: 12px;
             padding: 1px 8px; font-size: .8rem; }
    ul { padding-left: 20px; }
    a { color: #2563eb; word-break: break-all; }
    section { margin-bottom: 28px; }
    .empty { color: #888; font-style: italic; }
  </style>
</head>
<body>
  <h1>{{ title }}</h1>

  <div class="meta">
    <span><strong>URL:</strong> <a href="{{ url }}">{{ url }}</a></span>
    <span><strong>HTTP status:</strong> <span class="badge">{{ status }}</span></span>
    <span><strong>Links:</strong> {{ link_count }}</span>
  </div>

  <section>
    <h2>Content</h2>
    {% if paragraphs %}
      {% for para in paragraphs %}
        <p>{{ para }}</p>
      {% endfor %}
    {% else %}
      <p class="empty">No paragraph text found.</p>
    {% endif %}
  </section>

  <section>
    <h2>Extracted links ({{ link_count }})</h2>
    {% if links %}
      <ul>
        {% for href, text in links %}
          <li><a href="{{ href }}">{{ text }}</a> — <code>{{ href }}</code></li>
        {% endfor %}
      </ul>
    {% else %}
      <p class="empty">No links found.</p>
    {% endif %}
  </section>

  <footer style="font-size:.8rem;color:#999;">Generated by extract.py — demo only.</footer>
</body>
</html>
