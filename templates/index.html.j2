<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Link Data Extractor — Demo</title>
  <style>
    body { font-family: system-ui, Arial, sans-serif; max-width: 760px;
           margin: 40px auto; padding: 0 16px; color: #222; line-height: 1.5; }
    h1 { font-size: 1.4rem; }
    form { display: flex; gap: 8px; margin-bottom: 24px; }
    input[type=url] { flex: 1; padding: 8px 10px; font-size: 1rem;
                      border: 1px solid #ccc; border-radius: 6px; }
    button { padding: 8px 16px; font-size: 1rem; border: 0; border-radius: 6px;
             background: #2563eb; color: #fff; cursor: pointer; }
    .meta { background: #f4f6f8; border-radius: 8px; padding: 12px 16px;
            font-size: .9rem; margin-bottom: 24px; }
    .meta span { display: inline-block; margin-right: 18px; }
    .badge { background: #2563eb; color: #fff; border-radius: 12px;
             padding: 1px 8px; font-size: .8rem; }
    .error { background: #fdecea; color: #b3261e; padding: 12px 16px;
             border-radius: 8px; }
    ul { padding-left: 20px; }
    a { color: #2563eb; word-break: break-all; }
    section { margin-bottom: 28px; }
    .empty { color: #888; font-style: italic; }
  </style>
</head>
<body>
  <h1>Link Data Extractor</h1>

  <form method="get" action="/">
    <input type="url" name="url" placeholder="https://example.com"
           value="{{ url }}" required>
    <button type="submit">Extract</button>
  </form>

  {% if error %}
    <div class="error"><strong>Error:</strong> {{ error }}</div>
  {% endif %}

  {% if data %}
    <div class="meta">
      <span><strong>URL:</strong> <a href="{{ data.url }}">{{ data.url }}</a></span>
      <span><strong>HTTP status:</strong> <span class="badge">{{ data.status }}</span></span>
      <span><strong>Links:</strong> {{ data.link_count }}</span>
    </div>

    <section>
      <h2>{{ data.title }}</h2>
      {% if data.paragraphs %}
        {% for para in data.paragraphs %}
          <p>{{ para }}</p>
        {% endfor %}
      {% else %}
        <p class="empty">No paragraph text found.</p>
      {% endif %}
    </section>

    <section>
      <h2>Extracted links ({{ data.link_count }})</h2>
      {% if data.links %}
        <ul>
          {% for href, text in data.links %}
            <li><a href="{{ href }}">{{ text }}</a> — <code>{{ href }}</code></li>
          {% endfor %}
        </ul>
      {% else %}
        <p class="empty">No links found.</p>
      {% endif %}
    </section>
  {% endif %}

  <footer style="font-size:.8rem;color:#999;">Demo only — running on port 5001.</footer>
</body>
</html>
